    {
      "id": "GENUS_EMBERIZA",
      "name": "Emberiza",
      "rank": "GENUS",
      "description": "Seed-eating birds of open habitats. The Yellowhammer's lazy summer song is the defining sound of Swedish farmland hedgerows; it is now declining rapidly across Europe due to agricultural intensification. The Ortolan Bunting has collapsed in Sweden and is the subject of urgent conservation measures.",
      "lineage": "Eurasian Buntings",
      "children": [
        {
          "id": "EMBERIZA_CITRINELLA",
          "name": "Emberiza citrinella",
          "rank": "SPECIES",
          "commonName": "Yellowhammer",
          "lineage": "Eurasian Buntings",
          "continents": [
            "Australia"
          ],
          "subspeciesCount": 3,
          "description": "The yellowhammer is a passerine bird in the bunting family that is native to Eurasia and has been introduced to New Zealand and Australia. Most European birds remain in the breeding range year-round, but the eastern subspecies is partially migratory, with much of the population wintering further south. The male yellowhammer has a bright yellow head, streaked brown back, chestnut rump, and yellow under parts.",
          "sourcedFrom": "wikipedia"
        },
        {
          "id": "EMBERIZA_SCHOENICLUS",
          "name": "Emberiza schoeniclus",
          "rank": "SPECIES",
          "commonName": "Common reed bunting",
          "lineage": "Eurasian Buntings",
          "continents": [
            "Europe"
          ],
          "subspeciesCount": 12,
          "description": "The common reed bunting, or simply reed bunting, is a passerine bird in the bunting family Emberizidae. This species breeds throughout Europe and much of the Palearctic region. While most individuals migrate south in winter, those in the milder south and west of the range are resident.",
          "sourcedFrom": "wikipedia"
        },
