      "id": "GEN_PSEUDORYX",
      "name": "Pseudoryx",
      "rank": "GENUS",
      "description": "A monotypic genus containing the Saola, one of the world's rarest large mammals, discovered by science only in 1992 in the Annamite Mountains of Vietnam and Laos and never photographed alive in the wild by researchers.",
      "lineage": "Bovini",
      "children": [
        {
          "id": "SP_PSEUDORYX_NGHETINHENSIS",
          "name": "Pseudoryx nghetinhensis",
          "rank": "SPECIES",
          "commonName": "Saola",
          "lineage": "Bovini",
          "continents": [
            "AS"
          ],
          "description": "The Saola — dubbed the 'Asian unicorn' — was unknown to science until 1992 when skulls with unusually long, parallel horns were found in a hunter's house in Nghệ Tĩnh Province, Vietnam; it was formally described the following year. It inhabits the evergreen forests of the Annamite Mountains straddling Vietnam and Laos, but no wild individual has ever been observed by a scientist, and all camera-trap records are from automatic stations. Critically endangered due to snaring — the dominant hunting method across Indochina — which has emptied forests of large mammals regardless of their commercial value.",
          "subspeciesCount": 0
        }
      ]
    },
