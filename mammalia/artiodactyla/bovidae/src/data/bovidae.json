    {
      "id": "GEN_TRAGELAPHUS",
      "name": "Tragelaphus",
      "rank": "GENUS",
      "description": "The spiral-horned antelopes of sub-Saharan Africa — a genus of 8 large bovids of forests and dense bush, all displaying the characteristic twisted horns and white-striped or spotted flanks that define the Tragelaphini tribe.",
      "lineage": "Spiral-horned Antelope",
      "children": [
        {
          "id": "SP_TRAGELAPHUS_SCRIPTUS",
          "name": "Tragelaphus scriptus",
          "rank": "SPECIES",
          "commonName": "Bushbuck",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Bushbuck is the most widespread of the spiral-horned antelopes, found across sub-Saharan Africa from Senegal to Ethiopia and south to South Africa wherever dense undergrowth, forest edges, and riparian thickets occur. Solitary and largely nocturnal, it is one of the few antelopes that thrives near human settlements if cover is available. Males have twisted horns and striking white spots and stripes on a chestnut coat, while females are hornless and more uniformly reddish-brown.",
          "subspeciesCount": 7
        },
        {
          "id": "SP_TRAGELAPHUS_STREPSICEROS",
          "name": "Tragelaphus strepsiceros",
          "rank": "SPECIES",
          "commonName": "Greater Kudu",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Greater Kudu is Africa's tallest antelope after the giraffe, with males carrying magnificent spiralling horns that can exceed 1.8 m in length — used in combat by interlocking and twisting. It inhabits dry woodland, thornbush, and rocky hillsides from East Africa to southern Africa, where it browses on leaves, flowers, and pods. Despite being heavily hunted for its exceptional trophy horns, it remains relatively common and adapts well to farmland if cover is present.",
          "subspeciesCount": 3
        },
        {
          "id": "SP_TRAGELAPHUS_IMBERBIS",
          "name": "Tragelaphus imberbis",
          "rank": "SPECIES",
          "commonName": "Lesser Kudu",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Lesser Kudu is a slender, shy antelope of arid and semi-arid thornbush in East Africa, primarily in Ethiopia, Somalia, Kenya, and Tanzania, where it relies on dense acacia scrub for cover and browses on a wide range of leaves and fruits to meet its water requirements without drinking. Males display 10–14 lateral white stripes on their flanks and two prominent white throat patches. Near Threatened due to habitat degradation and hunting.",
          "subspeciesCount": 2
        },
        {
          "id": "SP_TRAGELAPHUS_EURYCERUS",
          "name": "Tragelaphus eurycerus",
          "rank": "SPECIES",
          "commonName": "Bongo",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Bongo is the largest forest antelope in the world, instantly recognisable by its vivid chestnut-red coat marked with 10–15 bold white vertical stripes, a white muzzle, and — uniquely for the genus — horns borne by both sexes. It inhabits dense tropical rainforest from West Africa through the Congo Basin to Kenya's montane forests, where it browses on leaves, bark, and roots. The highly isolated eastern mountain subspecies (T. e. isaaci) in Kenya's Aberdare Range and Mount Kenya is Critically Endangered with fewer than 100 individuals remaining in the wild.",
          "subspeciesCount": 2
        },
        {
          "id": "SP_TRAGELAPHUS_ANGASII",
          "name": "Tragelaphus angasii",
          "rank": "SPECIES",
          "commonName": "Nyala",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Nyala is among the most sexually dimorphic of all bovids: males are shaggy, slate-grey with white stripes and a yellow-orange lower body, standing almost 1.2 m at the shoulder with deeply spiralled horns, while females are bright chestnut with clear stripes and no horns. It inhabits dense lowland forest and riparian thickets in southeastern Africa from southern Malawi to KwaZulu-Natal. Named after George French Angas, an Australian naturalist who described it in 1849.",
          "subspeciesCount": 0,
          "namedAfter": "George French Angas"
        },
        {
          "id": "SP_TRAGELAPHUS_SPEKII",
          "name": "Tragelaphus spekii",
          "rank": "SPECIES",
          "commonName": "Sitatunga",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Sitatunga is the most aquatic of Africa's antelopes, inhabiting permanently flooded papyrus swamps, reed beds, and riverine forests across central and western Africa, from Senegal to Ethiopia and south to Zambia. Its elongated, splayed hooves, shaggy waterproof coat, and powerful hindquarters enable it to wade and swim through deep marsh vegetation in search of aquatic plants. Males bear gently twisted horns and a dark chocolate coat with faint white stripes; females are smaller and bright reddish-brown. Named after explorer John Hanning Speke.",
          "subspeciesCount": 8,
          "namedAfter": "John Hanning Speke"
        },
        {
          "id": "SP_TRAGELAPHUS_ORYX",
          "name": "Tragelaphus oryx",
          "rank": "SPECIES",
          "commonName": "Common Eland",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Common Eland is the world's largest antelope, with old bulls reaching 700–950 kg — yet despite this bulk it is remarkably agile and can clear a 2 m fence from a standstill. It inhabits open woodland, savanna, and montane grasslands across eastern and southern Africa, grazing and browsing with equal facility and obtaining sufficient water from its food to survive in arid regions. Both sexes carry spirally twisted horns, and a diagnostic dewlap develops in males with age. It has been semi-domesticated for meat and milk production in several African countries.",
          "subspeciesCount": 2
        },
        {
          "id": "SP_TRAGELAPHUS_DERBIANUS",
          "name": "Tragelaphus derbianus",
          "rank": "SPECIES",
          "commonName": "Giant Eland",
          "lineage": "Spiral-horned Antelope",
          "continents": [
            "AF"
          ],
          "description": "The Giant Eland surpasses even the Common Eland in shoulder height, with males reaching 1.76 m, and is the largest of all spiral-horned antelopes by stature. It inhabits woodland savanna and gallery forest in the Sahel belt from Senegal and The Gambia east to Sudan and the Central African Republic. The massive V-shaped horns of males can reach 1.2 m in length. The western subspecies (T. d. derbianus) is Critically Endangered with fewer than 200 individuals. Named after Edward Smith-Stanley, 13th Earl of Derby, a renowned Victorian naturalist and collector.",
          "subspeciesCount": 2,
          "namedAfter": "Edward Smith-Stanley, 13th Earl of Derby"
        }
      ]
    }
  ]
}