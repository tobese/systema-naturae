    {
      "id": "GENUS_SETONIX",
      "name": "Setonix",
      "rank": "GENUS",
      "description": "A monotypic genus and one of the smallest macropods. Setonix is most closely related to the pademelons (Thylogale) and shares with them a compact, stocky build suited to dense vegetation. Today it is essentially restricted to two small islands off Western Australia — Rottnest Island and Bald Island — though it once ranged across the mainland's south-west.",
      "lineage": "Wallabies",
      "children": [
        {
          "id": "SETONIX_BRACHYURUS",
          "name": "Setonix brachyurus",
          "rank": "SPECIES",
          "commonName": "Quokka",
          "lineage": "Wallabies",
          "continents": [
            "Oceania"
          ],
          "description": "The quokka's famously unguarded expression — a product of its relaxed jaw muscles — made it an internet celebrity. Dutch mariner Willem de Vlamingh mistook them for large rats in 1696, naming his landing spot 'Ratte nest' (Rottnest). Despite their approachable demeanour, quokkas are a threatened species; mainland populations cling on in scattered pockets of south-western Australia."
        }
      ]
